# Ignore UI job outputs and logs
ui/jobs/*
!ui/jobs/.gitkeep
ui/*.log

# Ignore input media files (audio, images, lyrics)
input/*.mp3
input/*.wav
input/*.flac
input/*.m4a
input/*.aac
input/*.ogg
input/*.mov
input/*.jpg
input/*.jpeg
input/*.png
input/*.webp
input/*.txt
input/*.srt
input/*.lrc

# Ignore output generated files
output/generated-videos/*.mp4
output/generated-videos/*.mov
output/generated-videos/*.jpg
output/generated-videos/*.jpeg
output/generated-videos/*.png
output/generated-videos/*.json
output/generated-videos/*.frame.jpg

# Ignore temp files
*.frame.jpg
generate.log

# Ignore config files with paths (may contain local paths)
# Keep example-config.json as reference
test-*.json
real-track-config.json
input/config.json
